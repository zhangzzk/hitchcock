# ── LLM (MIMO, OpenAI-compatible) ─────────────────────────────────────
HITCHCOCK_MIMO_API_KEY=""
HITCHCOCK_MIMO_BASE_URL="https://api.xiaomimimo.com/v1"
HITCHCOCK_MIMO_MODEL="mimo-v2-flash"

# ── Image & Video generation (Volcengine Ark, OpenAI-compatible) ──────
HITCHCOCK_ARK_API_KEY=""
HITCHCOCK_ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
# Image model — requires min ~3.7M pixels per image (≥ 2K) for 4.5; 4.0 accepts 1024.
HITCHCOCK_ARK_IMAGE_MODEL="doubao-seedream-4-5-251128"
# Video model — used by Shot Gen Agent later.
HITCHCOCK_ARK_VIDEO_MODEL="doubao-seedance-2-0-260128"

# ── Image generation (Google Nano Banana / Gemini) — primary backend ──
HITCHCOCK_GEMINI_API_KEY=""
HITCHCOCK_GEMINI_IMAGE_MODEL="nano-banana-pro-preview"

# ── Runtime ───────────────────────────────────────────────────────────
HITCHCOCK_BIBLE_DIR="./bible"
